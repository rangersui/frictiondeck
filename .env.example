# ── tokens ──────────────────────────────────────────────────
# Auth token — AI gets this (via MCP). Read/write worlds, use plugins.
ELASTIK_TOKEN=change-me
# Approve token — human only. Install plugins, admin ops, postman proxy.
# Never give to AI. If not set, a random one is printed at startup.
ELASTIK_APPROVE_TOKEN=change-me-too
# HMAC key — signs the audit chain. Change in production.
ELASTIK_KEY=elastik-dev-key

# ── server ──────────────────────────────────────────────────
ELASTIK_HOST=0.0.0.0
ELASTIK_PORT=3004

# ── bare metal ──────────────────────────────────────────────
# Docker users: ignore this. Container isolation protects you.
# Without Docker, exec and fs plugins are blocked by default.
# Uncomment ONLY if you understand the risk.
# ELASTIK_ALLOW_DANGEROUS=1

# ── public access (public_gate plugin) ─────────────────────
# Set ELASTIK_MCP_TOKEN to activate. Without it, public_gate is inert.
# ELASTIK_MCP_TOKEN=your-random-secret
# ELASTIK_SESSION_TTL=86400
# ELASTIK_KNOCK=/kn-secret-path1,/kn-secret-path2
# ELASTIK_KNOCK_WINDOW=10
# ELASTIK_KNOCK_TTL=600
# ELASTIK_TRUST_PROXY_HEADER=cf-connecting-ip
# ELASTIK_TRUST_PROXY_FROM=127.0.0.1/32
# ELASTIK_ANTHROPIC_IPS=160.79.104.0/21,2607:6bc0::/48

# ── Ollama (local LLM) ─────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b

# ── AI API keys (leave empty until needed) ──────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=
