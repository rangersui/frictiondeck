{
  "openapi": "3.1.0",
  "info": {
    "title": "elastik",
    "description": "HTTP API. Worlds store strings. Read and write with any path.",
    "version": "2.0.0"
  },
  "servers": [{"url": "https://your-tunnel.trycloudflare.com"}],
  "paths": {
    "/{path}": {
      "get": {
        "operationId": "http_get",
        "summary": "GET any path. /stages, /{name}/read, /{name}/raw, /info, etc.",
        "parameters": [
          {"name": "path", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {"200": {"description": "JSON or raw content"}}
      },
      "post": {
        "operationId": "http_post",
        "summary": "POST any path. /{name}/write, /{name}/append, plugin routes, etc.",
        "parameters": [
          {"name": "path", "in": "path", "required": true, "schema": {"type": "string"}},
          {"name": "ext", "in": "query", "schema": {"type": "string"}, "description": "File type hint (html, json, png, etc.)"}
        ],
        "requestBody": {
          "content": {
            "text/plain": {"schema": {"type": "string"}}
          }
        },
        "responses": {"200": {"description": "JSON result"}}
      }
    }
  }
}
